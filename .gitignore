data/*.zip
data/MOT17/
data/MOT17Labels/
data/MOT20/

# Hailo calibration images — regenerated by collect_calib.py
edge/calib_imgs/

# Generated figures and videos (reproducible from notebooks)
results/**/*.pdf
results/**/*.png
results/**/*.html
results/**/*.mp4

# IDE / OS
.DS_Store
