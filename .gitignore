# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.venv/
*.log

# Jupyter
.ipynb_checkpoints/

# Large model binaries — download/export separately
# .hef files are tracked via Git LFS (see .gitattributes)
models/*.pt
models/*.onnx
models/*.har
models/*.engine
models/*_ncnn_model/
notebooks/*.pt

# Hailo proprietary wheels — not redistributable; place manually
edge/hailo-wheels/*.whl

# Dataset archives and raw sequences — too large for git
data/*.zip
data/MOT17/
data/MOT17Labels/
data/MOT20/

# Hailo calibration images — regenerated by collect_calib.py
edge/export/calib_imgs/

# QNN / Adreno GPU pipeline — dropped; not production-ready on QRB2210 aarch64
edge/export_qnn.py
edge/export_results_qnn.csv
edge/profiles/arduino_uno_q_qnn.yaml
src/benchmark/qnn_runner.py
docs/pytorch_to_adreno_gpu.md

# Generated figures and videos (reproducible from notebooks)
results/**/*.pdf
results/**/*.png
results/**/*.html
results/**/*.mp4

# IDE / OS
.DS_Store
debug/
archive/

# Project specific
edge/export/logs/
results/raw/desktop/*.csv

# Ignore docs
docs/